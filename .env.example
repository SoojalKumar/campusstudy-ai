S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=campusstudy-ai
S3_REGION=us-east-1
ENABLE_MOCK_AI=true
LLM_PROVIDER=mock
LLM_MODEL=llama-4-scout
